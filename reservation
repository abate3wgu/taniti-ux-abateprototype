<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Event Reservation | Taniti Island</title>
  <link rel="stylesheet" href="css/styles.css" />

  <!-- Calendly inline widget CSS/JS -->
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
  <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>

  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
    }

    header, main, footer {
      padding: 20px;
    }

    nav a {
      margin-right: 15px;
      text-decoration: none;
    }

    .hero {
      padding: 30px;
      border-radius: 10px;
      margin-bottom: 20px;
    }

    .event-card {
      max-width: 900px;
      margin: auto;
    }

    .reserve-btn {
      display: inline-block;
      padding: 12px 20px;
      margin-top: 15px;
      text-decoration: none;
      border-radius: 8px;
    }

    .calendly-inline-widget {
      min-width: 320px;
      height: 700px;
      margin-top: 30px;
    }
  </style>
</head>
<body>
  <header>
    <h1>Taniti Island Event Reservation</h1>
    <nav>
      <a href="index.html">Home</a>
      <a href="reservation.html">Reservations</a>
    </nav>
  </header>

  <main>
    <section class="hero event-card">
      <h2>Reserve Your Spot</h2>
      <p><strong>Event:</strong> Island Cultural Experience</p>
      <p><strong>Location:</strong> Taniti Island Community Center</p>
      <p><strong>Description:</strong> Join us for a guided island event featuring local culture, music, food, and family-friendly activities.</p>
      <p><strong>Duration:</strong> 2 hours</p>
      <p><strong>Reservation Required:</strong> Yes</p>

      <a class="reserve-btn" href="#booking">Book Now</a>
    </section>

    <section id="booking" class="event-card">
      <h2>Choose Your Date and Time</h2>
      <p>Please select an available time below to complete your reservation.</p>

      <!-- Replace the URL below with your real Calendly booking link -->
      <div class="calendly-inline-widget"
           data-url="https://calendly.com/YOUR-USERNAME/YOUR-EVENT"
           style="min-width:320px;height:700px;">
      </div>
    </section>
  </main>

  <footer>
    <p>&copy; 2026 Taniti Island</p>
  </footer>
</body>
</html>
